  "cluster_CFA": {
    "clustering_name": "cluster_CFA",
    "clustering_description": {
      "cluster_CFA": "Image features based on Color Filter Array interpolation artifacts. Detects CFA interpolation patterns by applying multiple filters (Laplacian, Prewitt, etc.) and extracts statistical features (mean, variance, skewness, kurtosis, zero-crossing rate), texture features (GLCM contrast, correlation, energy, homogeneity), block-wise features (statistics of block variance and mean), and periodicity features (FFT frequency domain analysis of 2x2 periodic patterns and energy distribution)"
